# Copy to terraform.tfvars (gitignored) and fill in your real values.
#
# admin_cidrs: the source IP(s) allowed to reach Splunk Web on port 8000.
# Lock this to your own public IP as a /32. Find it with:  curl -s ifconfig.me
# Home/ISP IPs can change — update this and re-apply if Splunk Web stops loading.
admin_cidrs = ["203.0.113.4/32"]
